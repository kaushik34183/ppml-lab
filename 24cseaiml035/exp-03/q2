if d>0:
    r1=(-b + math.sqrt(d))/ (2*a)
    r2=(-b + math.sqrt(d))/ (2*a)
    print("root1",r1)
    print("root2",r2)
elif d==0:
    r=-b/(2*a)
    print("one real root",r)
else:
    print("no real roots")