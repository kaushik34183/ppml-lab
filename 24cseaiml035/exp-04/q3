def gcd(a, b):
    while b != 0:
        a, b = b, a % b
    return a

num1 = int(input("Enter first number: "))
num2 = int(input("Enter second number: "))
num3 = int(input("Enter third number: "))

result = gcd(gcd(num1, num2), num3)
print(f"GCD of {num1}, {num2}, and {num3} is {result}")
